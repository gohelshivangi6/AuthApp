{
  "presets": {
    "primary": { "primary": true, "sortable": true, "width": "220px", "sticky": true },
    "num":     { "sortable": true, "align": "right", "numberFormat": true },
    "currency":{ "render": "currency", "align": "right", "sortable": true },
    "pct":     { "render": "percentage", "sortable": true },
    "badge":   { "render": "badge", "sortable": true },
    "status":  { "render": "status", "sortable": true },
    "date":    { "render": "date", "sortable": true }
  },
  "levels": [
    ["Zone Head", "GroupsIcon", "#6366f1"],
    ["CSO", "SupportAgentIcon", "#a855f7"],
    ["ASM", "PeopleAltIcon", "#10b981"],
    ["DB", "StorefrontIcon", "#f59e0b"],
    ["Product", "Inventory2Icon", "#3b82f6"],
    ["CKU", "FactCheckIcon", "#ec4899"]
  ],
  "columns": {
    "Zone Head": [
      ["name", "Zone Head", "$primary"],
      ["zone", "Zone"],
      ["region", "Region"],
      ["employees", "Employees", "$num"],
      ["performance", "Performance", "$pct", { "pctOf": "target", "achOf": "achieved" }],
      ["target", "Target", "$currency"],
      ["achieved", "Achieved", "$currency"]
    ],
    "CSO": [
      ["name", "CSO Name", "$primary"],
      ["territory", "Territory"],
      ["stores", "Stores", "$num"],
      ["asmCount", "ASMs", "$num"],
      ["target", "Target", "$currency"],
      ["achieved", "Achieved", "$currency"]
    ],
    "ASM": [
      ["name", "ASM Name", "$primary"],
      ["area", "Area"],
      ["distributors", "Distributors", "$num"],
      ["target", "Target", "$currency"],
      ["achieved", "Achieved", "$currency"]
    ],
    "DB": [
      ["name", "Distributor", "$primary"],
      ["location", "Location"],
      ["creditRating", "Credit", "$badge"],
      ["outstanding", "Outstanding", "$currency"]
    ],
    "Product": [
      ["name", "Product", "$primary"],
      ["category", "Category"],
      ["sku", "SKU"],
      ["stock", "Stock", "$num", { "render": "progress", "progressMax": 1000 }],
      ["sales", "Sales", "$currency"]
    ],
    "CKU": [
      ["name", "CKU ID", "$primary"],
      ["status", "Status", "$status"],
      ["lastChecked", "Last Checked", "$date"],
      ["notes", "Notes"]
    ]
  },
  "table": {
    "searchable": true,
    "searchFields": ["name", "zone", "region", "territory", "area", "location", "category", "sku", "status"],
    "pageSize": 10,
    "emptyMessage": "No records found at this level.",
    "striped": true,
    "exportable": ["csv"],
    "printable": true,
    "hoverColor": "rgba(99, 102, 241, 0.06)",
    "currency": {
      "symbol": "₹",
      "units": [
        { "threshold": 10000000, "suffix": "Cr" },
        { "threshold": 100000, "suffix": "L" },
        { "threshold": 1000, "suffix": "K" }
      ]
    }
  },
  "theme": {
    "primaryColor": "#6366f1",
    "borderRadius": "16px",
    "fontFamily": "Inter, sans-serif",
    "headingFontFamily": "Outfit, sans-serif"
  }
}
