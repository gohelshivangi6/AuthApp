{
  "levels": [
    { "key": "Zone Head", "icon": "GroupsIcon", "color": "#6366f1", "drillable": true, "subtitle": "Regional managers", "labelField": "name" },
    { "key": "CSO", "icon": "SupportAgentIcon", "color": "#a855f7", "drillable": true, "subtitle": "Chief Sales Officers" },
    { "key": "ASM", "icon": "PeopleAltIcon", "color": "#10b981", "drillable": true, "subtitle": "Area Sales Managers" },
    { "key": "DB", "icon": "StorefrontIcon", "color": "#f59e0b", "drillable": true, "subtitle": "Distributors" },
    { "key": "Product", "icon": "Inventory2Icon", "color": "#3b82f6", "drillable": true, "subtitle": "Product catalog" },
    { "key": "CKU", "icon": "FactCheckIcon", "color": "#ec4899", "drillable": false, "subtitle": "Check units" }
  ],
  "columns": {
    "Zone Head": [
      { "field": "name", "label": "Zone Head", "primary": true, "sortable": true, "width": "220px", "sticky": true },
      { "field": "zone", "label": "Zone", "sortable": true },
      { "field": "region", "label": "Region", "sortable": true },
      { "field": "employees", "label": "Employees", "sortable": true, "align": "right", "numberFormat": true },
      { "field": "performance", "label": "Performance", "render": "percentage", "percentageOf": "target", "achievedOf": "achieved", "sortable": true },
      { "field": "target", "label": "Target", "render": "currency", "align": "right", "sortable": true },
      { "field": "achieved", "label": "Achieved", "render": "currency", "align": "right", "sortable": true }
    ],
    "CSO": [
      { "field": "name", "label": "CSO Name", "primary": true, "sortable": true, "width": "220px", "sticky": true },
      { "field": "territory", "label": "Territory", "sortable": true },
      { "field": "stores", "label": "Stores", "sortable": true, "align": "right", "numberFormat": true },
      { "field": "asmCount", "label": "ASMs", "sortable": true, "align": "right" },
      { "field": "target", "label": "Target", "render": "currency", "align": "right", "sortable": true },
      { "field": "achieved", "label": "Achieved", "render": "currency", "align": "right", "sortable": true }
    ],
    "ASM": [
      { "field": "name", "label": "ASM Name", "primary": true, "sortable": true, "width": "220px", "sticky": true },
      { "field": "area", "label": "Area", "sortable": true },
      { "field": "distributors", "label": "Distributors", "sortable": true, "align": "right" },
      { "field": "target", "label": "Target", "render": "currency", "align": "right", "sortable": true },
      { "field": "achieved", "label": "Achieved", "render": "currency", "align": "right", "sortable": true }
    ],
    "DB": [
      { "field": "name", "label": "Distributor", "primary": true, "sortable": true, "width": "220px", "sticky": true },
      { "field": "location", "label": "Location", "sortable": true },
      { "field": "creditRating", "label": "Credit", "render": "badge", "sortable": true },
      { "field": "outstanding", "label": "Outstanding", "render": "currency", "align": "right", "sortable": true }
    ],
    "Product": [
      { "field": "name", "label": "Product", "primary": true, "sortable": true, "width": "220px", "sticky": true },
      { "field": "category", "label": "Category", "sortable": true },
      { "field": "sku", "label": "SKU", "sortable": true },
      { "field": "stock", "label": "Stock", "align": "right", "numberFormat": true, "sortable": true, "render": "progress", "progressMax": 1000 },
      { "field": "sales", "label": "Sales", "render": "currency", "align": "right", "sortable": true }
    ],
    "CKU": [
      { "field": "name", "label": "CKU ID", "primary": true, "sortable": true, "width": "220px", "sticky": true },
      { "field": "status", "label": "Status", "render": "status", "sortable": true },
      { "field": "lastChecked", "label": "Last Checked", "render": "date", "sortable": true },
      { "field": "notes", "label": "Notes" }
    ]
  },
  "table": {
    "searchable": true,
    "searchFields": ["name", "zone", "region", "territory", "area", "location", "category", "sku", "status"],
    "pageSize": 10,
    "emptyMessage": "No records found at this level.",
    "rootLabel": "All Zones",
    "dense": false,
    "striped": true,
    "exportable": ["csv"],
    "printable": true,
    "maxDepth": 6,
    "rowClick": "drill",
    "hoverColor": "rgba(99, 102, 241, 0.06)",
    "currency": {
      "symbol": "\u20B9",
      "units": [
        { "threshold": 10000000, "suffix": "Cr" },
        { "threshold": 100000, "suffix": "L" },
        { "threshold": 1000, "suffix": "K" }
      ]
    }
  },
  "theme": {
    "primaryColor": "#6366f1",
    "borderRadius": "16px",
    "fontFamily": "Inter, sans-serif",
    "headingFontFamily": "Outfit, sans-serif"
  }
}
